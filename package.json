{
  "name": "lab2excel-converter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@types/express": "^5.0.6",
    "esbuild": "^0.28.1",
    "express": "^5.2.1",
    "peerjs": "1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-qr-code": "2.0.15",
    "tsx": "^4.22.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
